{
  "manifest_version": 3,
  "name": "hecate",
  "version": "0.1.0",
  "description": "hecate — cross-browser bookmark manager (thin client for the local native app)",
  "key": "",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "hecate"
  }
}
